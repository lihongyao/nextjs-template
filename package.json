{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development APP_ENV=dev next dev",
    "dev:qa": "cross-env NODE_ENV=development APP_ENV=qa next dev",
    "dev:prod": "cross-env NODE_ENV=development APP_ENV=prod next dev",
    "build:qa": "cross-env NODE_ENV=production APP_ENV=qa next build",
    "build:prod": "cross-env NODE_ENV=production APP_ENV=prod next build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm lint"
    ]
  },
  "dependencies": {
    "next": "16.0.1",
    "next-intl": "^4.4.0",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
